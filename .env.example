# =============================================================================
# Ease — Environment Variables Template
# Copy to .env.local for local development. Never commit .env.local.
# Production/Preview values are set in Vercel dashboard -> Settings -> Env Vars.
# =============================================================================

# --- Database (Neon) --------------------------------------------------------
# Get both URLs from: Neon dashboard -> Project -> Connection Details
# DATABASE_URL: Pooled connection (for runtime queries via Drizzle)
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require&channel_binding=require"
# DATABASE_URL_UNPOOLED: Direct connection (for drizzle-kit migrations only)
DATABASE_URL_UNPOOLED="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# --- Clerk (Authentication) -------------------------------------------------
# Get from: Clerk dashboard -> API Keys
# Use your Development instance keys for local + preview; Production keys for prod.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Get from: Clerk dashboard -> Webhooks -> Add Endpoint -> Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs (these exact values are safe defaults -- change only if routing differs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Cloudflare R2 (File Storage) ------------------------------------------
# Get from: Cloudflare dashboard -> right sidebar -> Account ID
R2_ACCOUNT_ID="your-cloudflare-account-id"
# Get from: Cloudflare dashboard -> R2 -> Manage R2 API Tokens -> Create Token
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Bucket created in Cloudflare dashboard -> R2 -> Create Bucket
R2_BUCKET_NAME="ease-uploads"

# --- Application ------------------------------------------------------------
# Local development: http://localhost:3000
# Production: set to your Vercel domain after first deploy
NEXT_PUBLIC_APP_URL="http://localhost:3000"
